{
  "extends": ["next/core-web-vitals", "prettier"],
  "plugins": ["reduce-motion"],
  "rules": {
    "reduce-motion/no-gif-img": "error",
    "reduce-motion/no-unguarded-animation-class": "warn",
    "no-console": "error",
    "no-unused-vars": [
      "error",
      {
        "argsIgnorePattern": "^_",
        "varsIgnorePattern": "^_",
        "destructuredArrayIgnorePattern": "^_"
      }
    ],
    "prefer-const": "error",
    "no-var": "error",
    "eqeqeq": ["error", "always"],
    "curly": "off",
    "no-eval": "error",
    "no-implied-eval": "error",
    "no-new-func": "error",
    "no-return-await": "off",
    "require-await": "off",
    "no-throw-literal": "error",
    "prefer-promise-reject-errors": "error",
    "react/jsx-no-target-blank": "error",
    "react/no-dangerously-set-inner-html": "off",
    "react/no-unescaped-entities": "off",
    "react-hooks/rules-of-hooks": "error",
    "react-hooks/exhaustive-deps": "warn",
    "import/no-anonymous-default-export": "off"
  },
  "overrides": [
    {
      "files": ["src/lib/logger.js", "src/utils/helpers/logger.js", "src/utils/testTimezone.js"],
      "rules": {
        "no-console": "off"
      }
    }
  ]
}
